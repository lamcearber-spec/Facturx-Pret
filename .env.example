# ===========================================
# Factur-X Prêt Environment Configuration
# ===========================================

# ─── Frontend (Next.js) ─────────────────────
NEXT_PUBLIC_SITE_NAME=Factur-X Prêt
NEXT_PUBLIC_SITE_DOMAIN=facturx-pret.fr
NEXT_PUBLIC_APP_URL=https://facturx-pret.fr
NEXT_PUBLIC_API_URL=https://api.facturx-pret.fr

# ─── Backend (FastAPI) ──────────────────────
DEBUG=false
ENVIRONMENT=production

# CORS (comma-separated origins)
ALLOWED_ORIGINS=https://facturx-pret.fr,https://www.facturx-pret.fr

# ─── Azure OpenAI (AI-powered file parsing) ─
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview
